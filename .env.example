# API base URL (origin only — service paths include /api/...)
# Leave empty to use the built-in Next.js API routes on the same origin.
NEXT_PUBLIC_API_BASE_URL=

# Set to "true" to use local mock responses instead of the API
NEXT_PUBLIC_USE_MOCK_API=false

# Prisma — PostgreSQL (Runflare)
#
# 1) In Runflare DB panel: enable "دسترسی از راه دور" (Remote access)
# 2) Copy the public host/port shown after enabling (NOT spotidb-xhh-service — that is internal only)
# 3) Paste your connection string below:
#
# --- Runflare Production (سرویس Next.js — نه DB) ---
# از پنل spotidb دکمه کپی «uri (internal)» را بزن:
# DATABASE_URL=postgresql://postgres:PASSWORD@spotidb-xhh-service:5432/spotidbjlm_db
#
# --- Local dev (remote access) ---
# DATABASE_URL=postgresql://postgres:PASSWORD@remote-pishgaman.runflare.com:32210/spotidbjlm_db
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@PUBLIC_HOST:5432/spotidbjlm_db?sslmode=require"

# MeliPayamak OTP SMS (path includes your API key)
MELIPAYAMAK_OTP_PATH=/api/send/otp/17792cae51df43229727721a94fa64a9
# Or full URL:
# MELIPAYAMAK_OTP_URL=https://console.melipayamak.com/api/send/otp/YOUR_KEY

# Show OTP on screen instead of SMS — local dev only, never in production
# NEXT_PUBLIC_SHOW_DEV_OTP=true
