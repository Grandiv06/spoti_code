generator client {
  provider = "prisma-client-js"
}

// Local: SQLite (file:./dev.db)
// Railway: set provider to "postgresql" and DATABASE_URL to your Postgres URL
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum CourseCategory {
  frontend
  backend
  ai
  base
  mobile
  devops
}

enum CourseLevel {
  elementary
  intermediate
  advanced
}

enum CourseStatus {
  draft
  published
}

enum AppUserRole {
  ADMIN
  INSTRUCTOR
  USER
}

model User {
  id          String             @id
  phone       String             @unique
  email       String?            @unique
  fullName    String?
  role        AppUserRole        @default(USER)
  status      String             @default("active")
  plan        String             @default("Starter")
  nationalCode String?           @unique
  internalAdminNote String?
  lastLoginAt DateTime?
  enrollments CourseEnrollment[]
  orders      UserOrder[]
  tickets     SupportTicket[]
  profile     UserProfile?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

model UserProfile {
  id                  String   @id
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  occupation          String?
  about               String?
  location            String?
  githubLink          String?
  linkedinLink        String?
  mbtiType            String?
  personalWebsiteLink String?
  contacts            String?
  skills              String?
  image               String?
  bannerImage         String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Instructor {
  id                   String   @id
  slug                 String   @unique
  name                 String
  avatar               String
  displayTitle         String?
  shortBio             String?
  fullBiography        String?
  mainExpertise        String?
  teachingStyle        String?
  professionalBackground String?
  verified             Boolean  @default(true)
  coverImage           String?
  yearsOfExperience    Int?
  skills               Json?
  experiences          Json?
  certificates         Json?
  projects             Json?
  reviews              Json?
  socials              Json?
  publicVisibility     Json?
  courses              Course[]
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Course {
  id                 String         @id
  slug               String         @unique
  title              String
  shortDescription   String
  description        String
  aboutDescription   String?
  category           CourseCategory
  categoryTitle      String
  instructorId       String
  instructor         Instructor     @relation(fields: [instructorId], references: [id])
  cover              String
  thumbnail          String
  difficulty         String
  level              CourseLevel
  durationHours      Int
  studentsCount      Int            @default(0)
  price              Int
  rating             Float          @default(0)
  status             CourseStatus   @default(draft)
  revenue            BigInt         @default(0)
  specialWord        String?
  introVideo         String?
  introVideoDuration String?
  chapters           Json?
  faqs               Json?
  comments           Comment[]
  enrollments        CourseEnrollment[]
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([status])
  @@index([category])
}

model Comment {
  id                String    @id
  courseId          String
  course            Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  parentId          String?
  parent            Comment?  @relation("CommentThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies           Comment[] @relation("CommentThread")
  content           String
  rating            Int?
  authorId          String?
  authorName        String
  authorRole        String    @default("دانشجو")
  authorAvatar      String    @default("/images/student1.jpg")
  isInstructorReply Boolean   @default(false)
  createdAt         DateTime  @default(now())

  @@index([courseId])
  @@index([parentId])
}

model CourseEnrollment {
  id        String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  progress  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, courseId])
  @@index([userId])
}

model UserOrder {
  id            String   @id
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type          String   @default("payment")
  status        String   @default("pending")
  amount        Int      @default(0)
  description   String?
  paymentMethod String?
  trackingCode  String?
  productTitle  String?
  courseId      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId, status])
}

model SupportTicket {
  id        String                 @id
  userId    String
  user      User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  category  String                 @default("other")
  status    String                 @default("open")
  priority  String                 @default("medium")
  messages  SupportTicketMessage[]
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt

  @@index([userId, status])
}

model SupportTicketMessage {
  id         String        @id
  ticketId   String
  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  senderType String        @default("user")
  senderName String
  body       String
  createdAt  DateTime      @default(now())

  @@index([ticketId])
}
